# TSA KPI Dashboard — Environment Variables
# Copy this file to ".env" at the repo root and fill in real values.
# DO NOT commit .env (it is gitignored).

# === REQUIRED for full pipeline (refresh from Linear API) ===
LINEAR_API_KEY=lin_api_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# === OPTIONAL: Google Drive auto-upload of generated HTML ===
# Skip these if you only want to build the dashboard locally.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=
GOOGLE_USER_EMAIL=

# === OPTIONAL: HTTP server settings ===
# Port for the local Python HTTP server (serve_kpi.py). Defaults to 8787.
KPI_HTTP_PORT=8787
# Where build_html_dashboard.py writes KPI_DASHBOARD.html.
# Defaults to ~/Downloads. The EC2 systemd unit sets this to /opt/tsa-kpi/output.
KPI_OUTPUT_DIR=
